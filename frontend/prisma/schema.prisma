// Akrasia — Prisma schema for Vercel Postgres (Neon)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url       = env("POSTGRES_PRISMA_URL")       // pooled  — for all runtime queries
  directUrl = env("POSTGRES_URL_NON_POOLING")  // direct  — for migrations only
}

// ─────────────────────────────────────────
// CONTACTS — simple contact enquiries
// ─────────────────────────────────────────
model Contact {
  id         String        @id @default(cuid())
  name       String
  email      String
  message    String
  sourcePage String        @default("contact")
  ipHash     String?
  userAgent  String?
  status     ContactStatus @default(PENDING)
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt

  @@index([email])
  @@index([createdAt])
  @@map("contacts")
}

enum ContactStatus {
  PENDING
  REVIEWED
  REPLIED
  ARCHIVED
}

// ─────────────────────────────────────────
// ORDERS — full project quote requests
// ─────────────────────────────────────────
model Order {
  id             String      @id @default(cuid())
  name           String
  email          String
  phone          String?
  company        String?
  service        String
  projectType    String?
  budget         String?
  timeline       String?
  goals          String      @db.Text
  notes          String?     @db.Text
  communication  String?
  referralSource String?
  sourcePage     String      @default("start")
  ipHash         String?
  userAgent      String?
  status         OrderStatus @default(NEW)
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  @@index([email])
  @@index([status])
  @@index([createdAt])
  @@map("orders")
}

enum OrderStatus {
  NEW
  UNDER_REVIEW
  QUOTED
  ACCEPTED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}