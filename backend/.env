# ─────────────────────────────────────────────────────────────
# Akrasia Backend — Environment Variables
# Copy this file to .env and fill in real values.
# NEVER commit .env to version control.
# ─────────────────────────────────────────────────────────────

# ── Server
NODE_ENV=development
PORT=8000

# ── Database (PostgreSQL)
# Local:   postgresql://postgres:yourpassword@localhost:5432/akrasia_db
# Railway: postgresql://user:password@host:5432/dbname?sslmode=require
DATABASE_URL=postgresql://akrasia_user:devpassword@localhost:5432/akrasia_db?schema=public

# ── CORS (comma-separated allowed origins)
# Dev:  http://localhost:5500,http://127.0.0.1:5500
# Prod: https://akrasia-production.up.railway.app,https://ebe78a8f.akrasia-2up.pages.dev,https://teamakrasia.vercel.app
CORS_ORIGIN=http://localhost:5173,http://localhost:5500,http://127.0.0.1:5500,https://akrasia-production.up.railway.app,https://ebe78a8f.akrasia-2up.pages.dev,https://teamakrasia.vercel.app

# ── Email (Brevo API)
BREVO_API_KEY=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
BREVO_SENDER_NAME=Akrasia
BREVO_SENDER_EMAIL=teamtheakrasia@gmail.com
EMAIL_TO=teamtheakrasia@gmail.com

# ── JWT (for future admin panel)
JWT_SECRET=replace_with_a_64_char_random_string
JWT_EXPIRES_IN=7d

# ── Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=20
