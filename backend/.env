# ─────────────────────────────────────────────────────────────
#  Akrasia Backend — Environment Variables
# Copy this file to .env and fill in real values.
# NEVER commit .env to version control.
# ─────────────────────────────────────────────────────────────

# ── Server
NODE_ENV=development
PORT=8000

# ── Database (PostgreSQL)
# Local:   postgresql://postgres:yourpassword@localhost:5432/akrasia_db
# Railway: postgresql://user:password@host:5432/dbname?sslmode=require
DATABASE_URL=postgresql://akrasia_user:devpassword@localhost:5432/akrasia_db

# ── CORS (comma-separated allowed origins)
# Dev:  http://localhost:5500,http://127.0.0.1:5500
# Prod: https://akrasia.com,https://www.akrasia.com
CORS_ORIGIN=https://teamakrasia.vercel.app,http://localhost:5500,http://127.0.0.1:5500

# ── Email / SMTP
# For Gmail: enable App Passwords under Google Account > Security.
# Use the 16-char App Password as SMTP_PASS, NOT your Gmail login.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=teamtheakrasia@gmail.com
SMTP_PASS=xvreuafpptzhqrjl
EMAIL_FROM="Team Akrasia" <teamtheakrasia@gmail.com>
EMAIL_TO=teamtheakrasia@gmail.com

# ── JWT (for future admin panel)
JWT_SECRET=4f7c1d8ea2e3b9f65c08d1a49b7e3f2c5d6a7b8e9f01a2b3c4d5e6f7a8b9c0d1

JWT_EXPIRES_IN=7d

# ── Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=20
