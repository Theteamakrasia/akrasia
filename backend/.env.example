# Backend environment variables
# Copy to .env and fill in real values

NODE_ENV=development
PORT=8000

# Database (fill in when ready)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=startup_db
DB_USER=admin
DB_PASS=changeme

# Auth
JWT_SECRET=change_this_to_a_long_random_string
JWT_EXPIRES_IN=7d

# CORS
CORS_ORIGIN=http://localhost:3000
