# ─────────────────────────────────────────────────────────────
# Akrasia Backend — Environment Variables
# Copy this file to .env and fill in real values.
# NEVER commit .env to version control.
# ─────────────────────────────────────────────────────────────

# ── Server
NODE_ENV=development
PORT=8000

# ── Database (PostgreSQL)
# Local:   postgresql://postgres:yourpassword@localhost:5432/akrasia_db
# Railway: postgresql://user:password@host:5432/dbname?sslmode=require
DATABASE_URL=postgresql://postgres:yourpassword@localhost:5432/akrasia_db

# ── CORS (comma-separated allowed origins)
# Dev:  http://localhost:5500,http://127.0.0.1:5500
# Prod: https://akrasia-production.up.railway.app
CORS_ORIGIN=http://localhost:5500,http://127.0.0.1:5500

# ── Email (Resend API — replaces old SMTP/Gmail config)
# Get your API key from https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx
EMAIL_FROM="Akrasia" <onboarding@resend.dev>
EMAIL_TO=teamtheakrasia@gmail.com

# ── JWT (for future admin panel)
JWT_SECRET=replace_with_a_64_char_random_string
JWT_EXPIRES_IN=7d

# ── Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=20
